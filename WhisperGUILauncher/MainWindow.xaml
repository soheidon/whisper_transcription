<Window x:Class="WhisperGUILauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Whisper GUI Launcher"
        Icon="app.ico"
        Height="520" Width="560"
        MinHeight="400" MinWidth="420"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e"
        Loaded="Window_Loaded">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Whisper GUI Launcher"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="#e0e0e0" Margin="0,0,0,8"/>

        <!-- Status bar -->
        <Border Grid.Row="1" Background="#2d2d2d" CornerRadius="4"
                Padding="8,6" Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <TextBlock x:Name="StatusIcon" Text="●" FontSize="12"
                               Foreground="#888" VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <TextBlock x:Name="StatusLabel" Text="Ready"
                               Foreground="#c0c0c0" FontSize="13"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button x:Name="RecheckButton" Grid.Column="1"
                        Content="Recheck" Click="RecheckButton_Click"
                        FontSize="11" Padding="8,3"
                        Background="#3a3a3a" Foreground="#c0c0c0"
                        BorderBrush="#555"/>
            </Grid>
        </Border>

        <!-- Log area -->
        <RichTextBox x:Name="LogBox" Grid.Row="2"
                     IsReadOnly="True" IsDocumentEnabled="True"
                     Background="#252525" Foreground="#d4d4d4"
                     FontFamily="Consolas" FontSize="12"
                     BorderBrush="#3a3a3a" BorderThickness="1"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,6">
            <RichTextBox.Resources>
                <Style TargetType="{x:Type Paragraph}">
                    <Setter Property="Margin" Value="2,0,0,0"/>
                </Style>
            </RichTextBox.Resources>
        </RichTextBox>

        <!-- Setup / Install panel (contextual, shown when issues found) -->
        <Border x:Name="SetupPanel" Grid.Row="3"
                Background="#2d2d2d" CornerRadius="4"
                Padding="10,8" Margin="0,0,0,6"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Setup:"
                           Foreground="#e5c07b" FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel x:Name="SetupButtons" Grid.Column="1"
                            Orientation="Horizontal">
                    <Button x:Name="InstallCondaEnvBtn"
                            Content="Create Conda Env"
                            Click="InstallCondaEnv_Click"
                            FontSize="11" Padding="8,4" Margin="0,0,6,0"
                            Background="#5a4a1e" Foreground="#e5c07b"
                            BorderBrush="#8a7a2e"/>
                    <Button x:Name="InstallPipDepsBtn"
                            Content="Install pip deps"
                            Click="InstallPipDeps_Click"
                            FontSize="11" Padding="8,4" Margin="0,0,6,0"
                            Background="#5a4a1e" Foreground="#e5c07b"
                            BorderBrush="#8a7a2e"/>
                    <Button x:Name="InstallFfmpegBtn"
                            Content="Install ffmpeg"
                            Click="InstallFfmpeg_Click"
                            FontSize="11" Padding="8,4"
                            Background="#5a4a1e" Foreground="#e5c07b"
                            BorderBrush="#8a7a2e"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Bottom buttons -->
        <Border Grid.Row="4" Background="#2d2d2d" CornerRadius="4"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <CheckBox x:Name="AutoCloseCheckBox"
                          Grid.Column="0"
                          Content="Close launcher after GUI starts"
                          Foreground="#c0c0c0" FontSize="12"
                          VerticalAlignment="Center"
                          IsChecked="False"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="LaunchButton"
                            Content="Launch Whisper GUI"
                            Click="LaunchButton_Click"
                            IsDefault="True"
                            Background="#0078d4" Foreground="White"
                            BorderBrush="#0078d4"/>
                    <Button Content="Close"
                            Click="CloseButton_Click"
                            IsCancel="True"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
